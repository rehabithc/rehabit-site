<script>
function switchTab(tab: string) {
  document.querySelectorAll('.tab-btn').forEach((btn: Element) => {
    (btn as HTMLElement).classList.remove('active');
    if ((btn as HTMLElement).dataset.tab === tab) (btn as HTMLElement).classList.add('active');
  });
  ['concept', 'why'].forEach(sec => {
    const medical = document.getElementById(sec + '-medical');
    const corporate = document.getElementById(sec + '-corporate');
    if (medical) medical.style.display = tab === 'medical' ? '' : 'none';
    if (corporate) corporate.style.display = tab === 'corporate' ? '' : 'none';
  });
  document.getElementById('concept')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
(window as any).switchTab = switchTab;
</script>

